{
  "name": "@leesf/rhf-devtool-react",
  "type": "module",
  "version": "0.2.1",
  "description": "My custom react-hook-form devtool",
  "author": "LeeSF",
  "license": "MIT",
  "homepage": "https://github.com/LeeSF03/rhf-devtool/blob/main/README.md",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LeeSF03/rhf-devtool.git"
  },
  "bugs": {
    "url": "https://github.com/LeeSF03/rhf-devtool/issues"
  },
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "play": "vite",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "bumpp && pnpm publish",
    "prepublishOnly": "bun run build",
    "format": "prettier --write .",
    "lint": "eslint . --ext .ts,.tsx"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/browser-playwright": "^4.0.18",
    "bumpp": "^10.4.1",
    "eslint": "^10.0.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "prettier": "^3.8.1",
    "react-hook-form": "^7.71.2",
    "tsdown": "^0.21.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "vitest-browser-react": "^2.0.5"
  },
  "packageManager": "pnpm@10.17.1+sha512.17c560fca4867ae9473a3899ad84a88334914f379be46d455cbf92e5cf4b39d34985d452d2583baf19967fa76cb5c17bc9e245529d0b98745721aa7200ecaf7a",
  "dependencies": {
    "@tsdown/css": "^0.21.2"
  }
}
